# Required: Web -> Go API internal proxy
GO_API_URL=http://localhost:8080
INTERNAL_API_SECRET=change-me-to-same-value-as-go-api

# Required: Firebase auth (web login + session cookie verification)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Required: /amsadmin strong credentials
AMSADMIN_USER=strong-admin-user
AMSADMIN_PASSWORD=strong-admin-password

# Optional: invite/contact email sending via Resend
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Access by AMS <no-reply@yourdomain.com>"
CONTACT_TO_EMAIL=ops@yourdomain.com
