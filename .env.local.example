GO_API_URL=https://testapi.amsaccess.com
INTERNAL_API_SECRET=your-internal-api-secret

# Required: Firebase auth (web login + session cookie verification)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Required: /amsadmin strong credentials
AMSADMIN_USER=amsadmin
AMSADMIN_PASSWORD=your-strong-password
# Required: Firebase UID of a dedicated amsadmin service account user (used for Go API calls)
# Create a Firebase user for amsadmin, get its UID from Firebase Console → Authentication → Users
AMSADMIN_SERVICE_UID=

# Optional: invite/contact email sending via Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL="Access by AMS <admin@amsaccess.com>"
CONTACT_TO_EMAIL=admin@amsaccess.com
